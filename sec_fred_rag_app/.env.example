# ============================================================
# SEC + FRED RAG Application — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit the .env file to version control.
# ============================================================

# ── HuggingFace LLM (optional — defaults to google/flan-t5-base) ────────────
# Any text2text-generation model from HuggingFace Hub works here.
# Larger models give better answers but need more RAM/VRAM.
# HF_LLM_MODEL=Qwen/Qwen2.5-0.5B-Instruct

# ── FRED ────────────────────────────────────────────────────
# Free API key from: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# ── SEC EDGAR ────────────────────────────────────────────────
# EDGAR requires a User-Agent string in the format:
#   "Company/App Name your_email@example.com"
# See: https://www.sec.gov/developer
SEC_USER_AGENT=MyResearchApp your_email@example.com

# ── Data paths (optional — defaults shown) ──────────────────
# CHROMA_PATH=./data/chroma
# FRED_DATA_DIR=./data/fred
# SENTIMENT_PATH=./data/sentiment_scores.parquet
